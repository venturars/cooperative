{
  "name": "cooperative",
  "version": "0.5.1",
  "description": "SDK for Cooperative applications — token swaps, balances, and chain utilities powered by wagmi/viem",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "COOPERATIVE_API_BASE_URL=https://www.venturarodriguez.xyz/api tsup --minify",
    "build:dev": "COOPERATIVE_API_BASE_URL=http://localhost:4321/api tsup --sourcemap",
    "dev": "COOPERATIVE_API_BASE_URL=http://localhost:4321/api tsup --watch",
    "typecheck": "tsc --noEmit",
    "version:bump": "node scripts/bump-version.js",
    "version:dry-run": "node scripts/bump-version.js --dry-run",
    "release": "./scripts/release.sh",
    "prepublishOnly": "pnpm run build",
    "prepare": "pnpm run build",
    "docs:typecheck": "pnpm -C docs run typecheck",
    "docs:install": "pnpm -C docs install",
    "docs:dev": "pnpm -C docs run dev",
    "docs:build": "pnpm -C docs run build"
  },
  "peerDependencies": {
    "@wagmi/core": "3.4.2",
    "viem": "2.47.6"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@wagmi/core": "3.4.2",
    "tsup": "8.3.5",
    "typescript": "5.8.2",
    "viem": "2.47.6"
  }
}
